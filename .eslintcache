 Single from './Single';\r\nimport {\r\n  BrowserRouter as Router,\r\n  Switch,\r\n  Route,\r\n  Link,\r\n  useRouteMatch,\r\n  useParams\r\n} from \"react-router-dom\";\r\nimport Home from './Home';\r\nimport Header from './Header';\r\nimport Footer from './Footer';\r\nimport ShoppingCart from './ShoppingCart';\r\n\r\n\r\nfunction App() {\r\n  const [products, setProducts] = useState(null);\r\n\r\n  function getSales() {\r\n    base.fetch('products', {\r\n      context: this,\r\n      asArray: true\r\n    }).then(data => {\r\n      console.log(\"Success loading data :)\");\r\n      setProducts(data)\r\n    }).catch(error => {\r\n      console.log(\"Loading data error :/\");\r\n    })\r\n  }\r\n\r\n  useEffect(() => {\r\n    getSales();\r\n  }, []);\r\n\r\n  return (\r\n    <Router>\r\n      <div className=\"App\">\r\n        <Header />\r\n\r\n        <main>\r\n          <Switch>\r\n            <Route path=\"/\" exact>\r\n              <Home products={products} />\r\n            </Route>\r\n            <Route path=\"/product/:productName\" component={Single} />\r\n            <Route path=\"/shopping-cart\">\r\n              <ShoppingCart />\r\n            </Route>\r\n          </Switch>\r\n        </main>\r\n\r\n        <Footer />\r\n      </div>\r\n    </Router>\r\n  );\r\n}\r\n\r\nexport default App;\r\n",["70","71"],"D:\\kaldrma\\src\\reportWebVitals.js",[],"D:\\kaldrma\\src\\base.js",[],"D:\\kaldrma\\src\\Product.js",[],"D:\\kaldrma\\src\\Home.js",[],"D:\\kaldrma\\src\\Single.js",["72","73"],"import React, { useEffect, useState } from \"react\";\r\nimport { useParams } from \"react-router-dom\";\r\nimport base from \"./base\"\r\n\r\nfunction Single(props) {\r\n\r\n  const [products, setProducts] = useState();\r\n  const [items, setItems] = useState();\r\n  const productName = props.match.params.productName;\r\n\r\n  function getSales() {\r\n    base.fetch('products', {\r\n      context: this,\r\n      asArray: true\r\n    }).then(data => {\r\n      console.log(\"Success loading data :)\");\r\n      setProducts(data)\r\n    }).catch(error => {\r\n      console.log(\"Loading data error :/\");\r\n    })\r\n  }\r\n\r\n  useEffect(() => {\r\n    getSales();\r\n    products && productName &&\r\n      setItems(products.filter(product => product.name.replace(/\\s+/g, '-').toLowerCase() == productName))\r\n  }, [products]);\r\n\r\n\r\n  return (\r\n    <div className=\"product-page\">\r\n      {items &&\r\n        items.map((it) =>\r\n          it.name\r\n        )\r\n      }\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Single;","D:\\kaldrma\\src\\Header.js",[],"D:\\kaldrma\\src\\Footer.js",[],"D:\\kaldrma\\src\\ShoppingCart.js",[],"D:\\kaldrma\\src\\Registration.js",[],"D:\\kaldrma\\src\\redux\\createStore.js",[],"D:\\kaldrma\\src\\LogIn.js",[],"D:\\kaldrma\\src\\redux\\rootReducer.js",[],"D:\\kaldrma\\src\\SignUp.js",[],"D:\\kaldrma\\src\\SignIn.js",[],{"ruleId":"74","severity":1,"message":"75","line":4,"column":8,"nodeType":"76","messageId":"77","endLine":4,"endColumn":15},{"ruleId":"78","replacedBy":"79"},{"ruleId":"80","replacedBy":"81"},{"ruleId":"82","severity":1,"message":"83","line":26,"column":6,"nodeType":"84","endLine":26,"endColumn":31,"suggestions":"85"},{"ruleId":"82","severity":1,"message":"86","line":26,"column":7,"nodeType":"87","endLine":26,"endColumn":30},"no-unused-vars","'Product' is defined but never used.","Identifier","unusedVar","no-native-reassign",["88"],"no-negated-in-lhs",["89"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'productName' and 'products'. Either include them or remove the dependency array. You can also replace multiple useState variables with useReducer if 'setItems' needs the current value of 'products'.","ArrayExpression",["90"],"React Hook useEffect has a complex expression in the dependency array. Extract it to a separate variable so it can be statically checked.","LogicalExpression","no-global-assign","no-unsafe-negation",{"desc":"91","fix":"92"},"