= props.match.params.productName;\r\n\r\n  function getSales() {\r\n    base.fetch('products', {\r\n      context: this,\r\n      asArray: true\r\n    }).then(data => {\r\n      console.log(\"Success loading data :)\");\r\n      setProducts(data)\r\n    }).catch(error => {\r\n      console.log(\"Loading data error :/\");\r\n    })\r\n  }\r\n\r\n  useEffect(() => {\r\n    getSales();\r\n    products && productName &&\r\n      setItems(products.filter(product => product.name.replace(/\\s+/g, '-').toLowerCase() == productName))\r\n  }, [products]);\r\n\r\n\r\n  return (\r\n    <div className=\"product-page\">\r\n      {items &&\r\n        items.map((it) =>\r\n          it.name\r\n        )\r\n      }\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Single;","D:\\kaldrma\\src\\Header.js",["60","61","62","63","64"],"import React from \"react\";\r\nimport {\r\n  BrowserRouter as Router,\r\n  Switch,\r\n  Route,\r\n  Link,\r\n  useRouteMatch,\r\n  useParams\r\n} from \"react-router-dom\";\r\n\r\nfunction Header() {\r\n\r\n  return (\r\n    <div className=\"header-wrap\">\r\n      <div className=\"top-nav\">\r\n        <Link to=\"/shopping-cart\" className=\"flex-center relative\" title=\"Go to cart\">\r\n          <i class=\"gg-shopping-cart\"></i>\r\n          {/* <span>Shopping cart</span> */}\r\n          <span className=\"absolute\">1</span>\r\n        </Link>\r\n      </div>\r\n      <header className=\"App-header\">\r\n        <h1><Link to=\"/\">kald<span>R</span>ma</Link></h1>\r\n      </header>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Header;","D:\\kaldrma\\src\\Footer.js",["65","66","67","68","69"],"import React from \"react\";\r\nimport {\r\n  BrowserRouter as Router,\r\n  Switch,\r\n  Route,\r\n  Link,\r\n  useRouteMatch,\r\n  useParams\r\n} from \"react-router-dom\";\r\n\r\nfunction Footer() {\r\n\r\n  return (\r\n    <footer>\r\n      <Link to=\"/\">\r\n        <img alt=\"footer logo\" src=\"/footer-logo.png\" />\r\n        <span>KALDRMA</span>\r\n      